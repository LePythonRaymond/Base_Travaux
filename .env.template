# Postgres
POSTGRES_DB=merci_raymond
POSTGRES_USER=mr_app
POSTGRES_PASSWORD=__GENERATE__

# Streamlit
STREAMLIT_AUTH_USER=admin
# Generate via: docker run --rm caddy:2-alpine caddy hash-password
# IMPORTANT: wrap the value in SINGLE quotes so the $ characters in the bcrypt
# hash are not interpolated by docker-compose.
STREAMLIT_AUTH_PASSWORD_HASH='__GENERATE__'

# Gemini
GEMINI_API_KEY=__YOUR_KEY__

# Bordereau API (shared secret with Power Query in Vincent's Excel)
# Generate via: openssl rand -hex 32
BORDEREAU_API_KEY=__GENERATE_LONG_RANDOM__

# Optional: domain for Caddy (use 'localhost' for local dev)
PUBLIC_DOMAIN=localhost
