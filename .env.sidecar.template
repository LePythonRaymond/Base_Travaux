# Sidecar deploy env — copy to `.env` on the VPS and fill in. Do NOT commit the
# filled .env. `docker compose -f docker-compose.sidecar.yml` auto-reads `.env`.

# Hostname the pricing app answers on. Must resolve to this VPS (72.61.166.144)
# BEFORE first `up` so Traefik's TLS challenge succeeds.
#   nslookup prices.srv1082911.hstgr.cloud   → should return 72.61.166.144
PUBLIC_DOMAIN=prices.srv1082911.hstgr.cloud

# Pricing app's OWN database (isolated from n8n's postgres).
POSTGRES_DB=merci_raymond
POSTGRES_USER=mr_app
POSTGRES_PASSWORD=        # openssl rand -hex 24

# Google AI Studio key (Gemini — used by invoice OCR + matching in the app).
GEMINI_API_KEY=

# Random key the Google Sheet uses to read the live bordereau.
BORDEREAU_API_KEY=        # openssl rand -hex 32

# Admin login for the Streamlit UI (HTTP basic-auth at the proxy).
STREAMLIT_AUTH_USER=admin
# bcrypt hash — generate with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
#   (or: htpasswd -nbB admin 'YOUR_PASSWORD'  → keep only the part AFTER the colon)
STREAMLIT_AUTH_PASSWORD_HASH=
